{
  // Emits a CommonJS build into dist/ that the (CommonJS) NestJS backend can
  // require() natively, plus .d.ts for typechecking. Tests are excluded — they
  // run against the .ts source via vitest, never shipped.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
