# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Neon Postgres connection string (Neon dashboard → Project → Connection string).
# Use the pooled URL for app runtime; a direct (non-pooled) URL also works for dev.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Upstash Redis REST credentials (Upstash dashboard → your DB → REST API).
UPSTASH_REDIS_REST_URL="https://YOUR-DB-NAME.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REST_TOKEN"

# Money mode: "virtual" (v1) or "stripe" (later). Controls which PaymentProvider runs.
MONEY_MODE=virtual

# Clerk secret key (Clerk dashboard → API Keys → Secret key).
# Required for Clerk JWT verification in production and non-dev environments.
CLERK_SECRET_KEY="sk_test_..."

# Phone verifier: "stub" (dev/test) or "twilio" (later).
PHONE_VERIFIER=stub

# Fixed OTP code used by StubVerifier. Change this to anything 6 digits.
OTP_STUB_CODE=123456

# Chat provider: "stub" (dev — no credentials needed) or "stream" (prod).
CHAT_PROVIDER=stub

# Stream Chat credentials — only required when CHAT_PROVIDER=stream.
# Get these from your Stream dashboard (getstream.io → App → API Keys).
STREAM_API_KEY=
STREAM_API_SECRET=

# API port (optional; defaults to 3000).
PORT=3000
