# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Neon Postgres connection string (Neon dashboard → Project → Connection string).
# Use the pooled URL for app runtime; a direct (non-pooled) URL also works for dev.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Upstash Redis REST credentials (Upstash dashboard → your DB → REST API).
UPSTASH_REDIS_REST_URL="https://YOUR-DB-NAME.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REST_TOKEN"

# API port (optional; defaults to 3000).
PORT=3000
