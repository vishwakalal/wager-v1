// Wager data model. This is the schema source of truth for the backend.
// The full domain model (circles, bets, stakes, jobs) is built out across
// BUILD_PLAN phases. Phase 1 establishes auth's User and the append-only,
// double-entry money ledger (Wallet / Transaction / LedgerEntry).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  /// Clerk user ID (sub claim from the Clerk JWT).
  clerkId         String    @unique
  displayName     String?
  /// Unique handle chosen during onboarding. Stored lowercase. Required before
  /// the account is considered fully activated (alongside phone verification).
  username        String?   @unique
  /// Null until the user completes SMS OTP verification (spec §9.2).
  phone           String?   @unique
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?
  /// Non-null when the account has been soft-deleted (spec §9.5).
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallet           Wallet?
  memberships      CircleMembership[]
  betsCreated      Bet[]              @relation("BetCreator")
  lineSubmissions  LineSubmission[]
  lineDisputeVotes LineDisputeVote[]
  stakes           Stake[]

  @@map("users")
}

/// One wallet per user, plus a single SYSTEM wallet representing money entering
/// and leaving the platform (the external counterparty for deposits/withdrawals).
/// Balances are NEVER stored here — they are always derived by summing the
/// wallet's ledger entries.
model Wallet {
  id        String     @id @default(cuid())
  kind      WalletKind @default(USER)
  userId    String?    @unique
  createdAt DateTime   @default(now())

  user    User?         @relation(fields: [userId], references: [id])
  entries LedgerEntry[]

  @@map("wallets")
}

enum WalletKind {
  USER
  SYSTEM
}

/// A money operation. Groups the ledger entries it produced (which always sum to
/// zero). `idempotencyKey` makes deposit/withdraw safe to retry: the same key
/// never applies twice.
model Transaction {
  id             String          @id @default(cuid())
  type           TransactionType
  idempotencyKey String?         @unique
  metadata       Json?
  createdAt      DateTime        @default(now())

  entries LedgerEntry[]

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  HOLD
  RELEASE
  PAYOUT
}

/// A single append-only posting: a signed cent amount against one wallet bucket.
/// Rows are never updated or deleted. Sum of all entries across the table is
/// always exactly zero; a wallet's balance is the sum of its entries per bucket.
model LedgerEntry {
  id            String   @id @default(cuid())
  transactionId String
  walletId      String
  bucket        Bucket
  amount        Int // signed cents
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])
  wallet      Wallet      @relation(fields: [walletId], references: [id])

  @@index([walletId, bucket])
  @@index([transactionId])
  @@map("ledger_entries")
}

enum Bucket {
  AVAILABLE
  HELD
}

// ─── Circles ────────────────────────────────────────────────────────────────

/// A persistent, invite-only group within which bets are created (spec §2.1).
model Circle {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships CircleMembership[]
  bets        Bet[]

  @@map("circles")
}

enum MemberRole {
  CREATOR
  MEMBER
}

/// PENDING = invited, awaiting creator approval.
/// APPROVED = active member; joinedAt is set at approval time.
enum MemberStatus {
  PENDING
  APPROVED
}

model CircleMembership {
  id       String       @id @default(cuid())
  circleId String
  userId   String
  role     MemberRole   @default(MEMBER)
  status   MemberStatus @default(PENDING)
  /// Timestamp when the member was approved — used to detect mid-bet joiners
  /// (spec §2.1: joiners after a bet's staking window can't participate).
  joinedAt DateTime?
  createdAt DateTime    @default(now())

  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([userId])
  @@map("circle_memberships")
}

// ─── Bets ────────────────────────────────────────────────────────────────────

enum BetType {
  NUMERIC
  BINARY
}

enum BetDuration {
  ONE_DAY
  ONE_WEEK
  ONE_MONTH
}

/// Full lifecycle status for a bet (spec §5, §3, §8).
/// LINE_SETTING/LINE_CHALLENGE are NUMERIC only; all types pass through STAKING onward.
enum BetStatus {
  LINE_SETTING
  LINE_CHALLENGE
  STAKING
  ACTIVE
  CLOSED
  RESOLVED
  VOIDED
  CANCELLED
}

/// A wager created within a circle (spec §2.2, §3, §5).
model Bet {
  id          String      @id @default(cuid())
  circleId    String
  creatorId   String
  type        BetType
  duration    BetDuration
  status      BetStatus   @default(LINE_SETTING)
  description String
  /// Set after line reveal for NUMERIC bets; always null for BINARY.
  line        Decimal?    @db.Decimal(10, 4)
  /// Increments each time 50%+ dispute triggers a re-submission round (spec §3.1).
  lineRound   Int         @default(1)

  lineRevealedAt  DateTime?
  challengeEndsAt DateTime?
  stakingEndsAt   DateTime?
  activeUntil     DateTime?
  closedAt        DateTime?
  resolvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  circle           Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  creator          User              @relation("BetCreator", fields: [creatorId], references: [id])
  lineSubmissions  LineSubmission[]
  lineDisputeVotes LineDisputeVote[]
  stakes           Stake[]

  @@index([circleId])
  @@index([creatorId])
  @@index([status])
  @@map("bets")
}

/// A single blind line submission from one member for one round (spec §3.1).
/// Submissions for the current round are hidden until the creator reveals.
model LineSubmission {
  id        String   @id @default(cuid())
  betId     String
  userId    String
  value     Decimal  @db.Decimal(10, 4)
  round     Int
  createdAt DateTime @default(now())

  bet  Bet  @relation(fields: [betId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([betId, userId, round])
  @@index([betId])
  @@map("line_submissions")
}

/// A dispute vote during the LINE_CHALLENGE window (spec §3.1).
/// If ≥50% of eligible members vote, the line is re-set.
model LineDisputeVote {
  id        String   @id @default(cuid())
  betId     String
  userId    String
  round     Int
  createdAt DateTime @default(now())

  bet  Bet  @relation(fields: [betId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([betId, userId, round])
  @@index([betId])
  @@map("line_dispute_votes")
}

// ─── Stakes ──────────────────────────────────────────────────────────────────

enum StakeSide {
  OVER
  UNDER
  YES
  NO
}

/// One stake per user per bet (spec §4.1). effectiveAmount and refundAmount are
/// null until the staking window closes and the 5x cap is applied (spec §4.2).
model Stake {
  id              String    @id @default(cuid())
  betId           String
  userId          String
  side            StakeSide
  /// Original requested amount in cents.
  amount          Int
  /// Post-cap amount actually staked (set at window close).
  effectiveAmount Int?
  /// Cap excess returned to wallet (set at window close; 0 if no cap applied).
  refundAmount    Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bet  Bet  @relation(fields: [betId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([betId, userId])
  @@index([betId])
  @@map("stakes")
}

// ─── Scheduling engine ───────────────────────────────────────────────────────

/// All timed state-machine transitions live here (spec §2.4).
/// The worker polls this table every 10 s; transitions are idempotent.
/// LINE_CHALLENGE_EXPIRE: LINE_CHALLENGE → STAKING after 30 min (Phase 4)
/// STAKING_CLOSE: STAKING → ACTIVE (Phase 5)
/// STAKING_WARNING: notification 30 min before staking closes (Phase 10)
/// BET_EXPIRE: ACTIVE → CLOSED at expiry (Phase 7)
/// DISPUTE_CLOSE: CLOSED → RESOLVED/VOIDED after 24 h (Phase 7)
/// DISPUTE_WARNING: notification 2 h before dispute window closes (Phase 10)
enum JobType {
  LINE_CHALLENGE_EXPIRE
  STAKING_CLOSE
  STAKING_WARNING
  BET_EXPIRE
  DISPUTE_CLOSE
  DISPUTE_WARNING
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

model ScheduledJob {
  id        String    @id @default(cuid())
  type      JobType
  runAt     DateTime
  payload   Json
  status    JobStatus @default(PENDING)
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, runAt])
  @@map("scheduled_jobs")
}
